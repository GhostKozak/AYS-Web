# ============================================================
# AYS-WEB Frontend — Environment Variables (Vite)
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env file to version control!
# All variables must be prefixed with VITE_ to be exposed to the browser.
# ============================================================

# --- API & Backend ---
# Base URL for REST API calls (used by axios in apiClient.ts)
VITE_API_BASE_URL="http://localhost:3000"
# Backend URL for WebSocket connection in development (used by socket.ts)
# In production this is derived from the same origin, so leave it as-is.
VITE_BACKEND_URL="http://localhost:3000"

# --- Application Information ---
VITE_APP_NAME="AYS"
VITE_APP_TITLE="AYS | Araç Yönetim Sistemi"
VITE_APP_VERSION="1.0.0"

# --- SEO and Meta Data ---
VITE_APP_DESCRIPTION="Araç ve sefer yönetimi için kurumsal takip sistemi."
VITE_APP_KEYWORDS="araç, sefer, lojistik, yönetim, takip"
VITE_APP_AUTHOR="AYS"

# --- Application Settings ---
VITE_DEFAULT_PAGE_SIZE="10"
VITE_DEFAULT_LOCALE="tr-TR"

# --- For Developer ---
VITE_ENABLE_DEBUG="false"